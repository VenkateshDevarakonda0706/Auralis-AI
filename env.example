# Core app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
# Supabase direct connection (recommended first)
DATABASE_URL=postgresql://postgres:replace-with-real-db-password@db.<project-ref>.supabase.co:5432/postgres
# Optional: Supabase pooler URL for IPv4-restricted networks
DATABASE_URL_POOLER=
# Optional: set to 1 to force using DATABASE_URL_POOLER
DATABASE_URL_USE_POOLER=0

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Google AI
GOOGLE_AI_API_KEY=replace-with-google-ai-api-key

# Murf AI
MURF_API_KEY=replace-with-murf-api-key
